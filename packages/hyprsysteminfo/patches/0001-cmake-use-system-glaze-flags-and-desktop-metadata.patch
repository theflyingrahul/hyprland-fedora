From: HyprWM Fedora maintainers
Date: Wed, 15 Jul 2026 00:00:00 +0000
Subject: [PATCH] cmake: use system Glaze, Fedora flags, and desktop metadata

Fedora builds must not download dependencies during configuration. Require
the packaged Glaze CMake target, retain distribution compiler flags, and
complete the desktop entry's menu metadata.
---
 CMakeLists.txt                                | 15 +--------------
 assets/install/hyprsysteminfo.desktop         |  2 ++
 2 files changed, 3 insertions(+), 14 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index dcfcc1a..3995657 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -18,19 +18,7 @@
 set(INCLUDE ${CMAKE_INSTALL_FULL_INCLUDEDIR})
 set(LIBDIR ${CMAKE_INSTALL_FULL_LIBDIR})
 
-find_package(glaze QUIET)
-if (NOT glaze_FOUND)
-    set(GLAZE_VERSION v6.1.0)
-    message(STATUS "glaze dependency not found, retrieving ${GLAZE_VERSION} with FetchContent")
-    include(FetchContent)
-    FetchContent_Declare(
-        glaze
-        GIT_REPOSITORY https://github.com/stephenberry/glaze.git
-        GIT_TAG ${GLAZE_VERSION}
-        GIT_SHALLOW TRUE
-    )
-    FetchContent_MakeAvailable(glaze)
-endif()
+find_package(glaze CONFIG REQUIRED)
 
 find_package(PkgConfig REQUIRED)
 pkg_check_modules(
@@ -58,7 +46,6 @@
   message(STATUS "Configuring hyprsysteminfo in Debug")
   add_compile_definitions(hyprsysteminfo_DEBUG)
 else()
-  add_compile_options(-O3)
   message(STATUS "Configuring hyprsysteminfo in Release")
 endif()
 
diff --git a/assets/install/hyprsysteminfo.desktop b/assets/install/hyprsysteminfo.desktop
index d75b2c8..98fa663 100644
--- a/assets/install/hyprsysteminfo.desktop
+++ b/assets/install/hyprsysteminfo.desktop
@@ -7,3 +7,5 @@
 Icon=hwinfo
 Terminal=false
 Type=Application
+Categories=System;Utility;
+Keywords=Hyprland;System;Information;Hardware;
