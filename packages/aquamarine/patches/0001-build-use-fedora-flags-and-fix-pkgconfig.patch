From: HyprWM Fedora maintainers
Subject: [PATCH] build: use Fedora flags and fix pkg-config dependencies

Installed public headers include hyprutils, Wayland client, and libdrm
headers. Advertise those dependencies and leave optimization to Fedora.

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -53,7 +53,6 @@
   message(STATUS "Configuring aquamarine in Debug")
   add_compile_definitions(AQUAMARINE_DEBUG)
 else()
-  add_compile_options(-O3)
   message(STATUS "Configuring aquamarine in Release")
 endif()
 
--- a/aquamarine.pc.in
+++ b/aquamarine.pc.in
@@ -6,5 +6,6 @@
 URL: https://github.com/hyprwm/aquamarine
 Description: A very light linux rendering backend library
 Version: @AQUAMARINE_VERSION@
+Requires: hyprutils wayland-client libdrm
 Cflags: -I${includedir}
 Libs: -L${libdir} -laquamarine
