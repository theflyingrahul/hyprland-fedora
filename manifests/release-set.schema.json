{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyprwm-fedora.invalid/schemas/release-set.schema.json",
  "title": "HyprWM Fedora release set",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "fedora_release",
    "revision",
    "architectures",
    "packages"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "fedora_release": {
      "type": "integer",
      "minimum": 1
    },
    "revision": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}-[0-9]+$"
    },
    "architectures": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "x86_64"
          }
        },
        {
          "contains": {
            "const": "aarch64"
          }
        }
      ],
      "items": {
        "enum": [
          "x86_64",
          "aarch64"
        ]
      }
    },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/package"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "filename",
        "url",
        "sha256",
        "provenance",
        "reference"
      ],
      "additionalProperties": false,
      "properties": {
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._+~-]*$"
        },
        "url": {
          "type": "string",
          "pattern": "^https://"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "provenance": {
          "enum": [
            "official-upstream",
            "official-fedora"
          ]
        },
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "package": {
      "type": "object",
      "required": [
        "path",
        "version",
        "release",
        "tier",
        "build_after",
        "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^packages/[A-Za-z0-9][A-Za-z0-9._+-]*$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "release": {
          "type": "integer",
          "minimum": 1
        },
        "tier": {
          "type": "integer",
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        },
        "update_policy": {
          "enum": [
            "automatic",
            "manual",
            "pinned"
          ]
        },
        "update_reason": {
          "type": "string",
          "minLength": 1
        },
        "build_after": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    }
  }
}
