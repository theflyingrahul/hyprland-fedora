class PackagingError(RuntimeError):
    pass


def run(command: list[str], *, cwd: Path | None = None) -> None:
    print("+", " ".join(command), file=sys.stderr, flush=True)
    subprocess.run(command, cwd=cwd, check=True)


def output(command: list[str], *, cwd: Path | None = None) -> str:
    return subprocess.run(
        command,
        cwd=cwd,
        check=True,
        stdout=subprocess.PIPE,
        text=True,
    ).stdout


def require_command(name: str) -> None:
    if shutil.which(name) is None:
        raise PackagingError(f"required command is not installed: {name}")


def atomic_write_text(path: Path, content: str) -> None:
    temporary = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    try:
        temporary.write_text(content, encoding="utf-8")
        if path.exists():
            temporary.chmod(path.stat().st_mode)
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def load_manifest() -> dict[str, Any]:
    try:
        with MANIFEST_PATH.open(encoding="utf-8") as stream:
            data = json.load(stream)
    except (OSError, json.JSONDecodeError) as error:
        raise PackagingError(f"cannot load {MANIFEST_PATH}: {error}") from error

    if not isinstance(data, dict):
        raise PackagingError("release-set manifest must be a JSON object")
    return data


def packages_from(data: dict[str, Any]) -> dict[str, dict[str, Any]]:
    packages = data.get("packages")
    if not isinstance(packages, dict):
        raise PackagingError("manifest packages must be an object")
    return packages


def selected_packages(
    data: dict[str, Any], names: list[str] | None = None
) -> list[tuple[str, dict[str, Any]]]:
    packages = packages_from(data)
    if names:
        missing = sorted(set(names) - packages.keys())
        if missing:
            raise PackagingError(f"unknown package(s): {', '.join(missing)}")
        selected = [(name, packages[name]) for name in names]
    else:
        selected = list(packages.items())

    return [
        (name, package)
        for name, package in selected
        if package.get("enabled", True)
    ]


def package_path(package: dict[str, Any]) -> Path:
    relative = package.get("path")
    if not isinstance(relative, str):
        raise PackagingError("package path must be a string")
    path = (ROOT / relative).resolve()
    packages_root = (ROOT / "packages").resolve()
    if packages_root not in path.parents:
        raise PackagingError(f"package path escapes packages/: {relative}")
    return path


def spec_path(name: str, package: dict[str, Any]) -> Path:
    return package_path(package) / f"{name}.spec"


def sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as stream:
        for block in iter(lambda: stream.read(1024 * 1024), b""):
            digest.update(block)
    return digest.hexdigest()


def validate_local_inputs(
    name: str,
    package: dict[str, Any],
    spec_text: str,
) -> list[str]:
    errors: list[str] = []
    directory = package_path(package)
    version = str(package.get("version", ""))
    remote_filenames = {
        source.get("filename")
        for source in package.get("sources", [])
        if isinstance(source, dict)
    }
    referenced: dict[str, set[str]] = {"files": set(), "patches": set()}
    for directive, child_name in (("Source", "files"), ("Patch", "patches")):
        pattern = rf"^{directive}\d*:\s*(\S+)\s*$"
        for match in re.finditer(pattern, spec_text, re.MULTILINE):
            value = (
                match.group(1)
                .replace("%{name}", name)
                .replace("%{version}", version)
            )
            if directive == "Source" and (
                "://" in value or "%{url}" in value
            ):
                continue
            if "%" in value:
                continue
            filename = Path(value.split("#", 1)[0]).name
            referenced[child_name].add(filename)
            if (
                filename not in remote_filenames
                and not (directory / child_name / filename).is_file()
            ):
                errors.append(
                    f"{name}: {directive} input is missing from "
                    f"{child_name}/: {filename}"
                )

    for child_name, filenames in referenced.items():
        child = directory / child_name
        if not child.is_dir():
            continue
        unreferenced = sorted(
            item.name
            for item in child.iterdir()
            if item.is_file() and item.name not in filenames
        )
        if unreferenced:
            errors.append(
                f"{name}: unreferenced {child_name} input(s): "
                + ", ".join(unreferenced)
            )
    return errors


def validate_json_schema(data: dict[str, Any]) -> list[str]:
    try:
        from jsonschema import Draft202012Validator
    except ImportError:
        return ["python3-jsonschema is required for manifest validation"]

    schema_path = ROOT / "manifests" / "release-set.schema.json"
    try:
        schema = json.loads(schema_path.read_text(encoding="utf-8"))
        validator = Draft202012Validator(schema)
    except (OSError, json.JSONDecodeError) as error:
        return [f"cannot load manifest schema: {error}"]
    return [
        "schema: "
        + ".".join(str(part) for part in error.absolute_path)
        + (": " if error.absolute_path else "")
        + error.message
        for error in sorted(
            validator.iter_errors(data),
            key=lambda item: tuple(str(part) for part in item.path),
        )
    ]


def official_upstream_allowed(package_name: str, url: str) -> bool:
    parsed = urlparse(url)
    if (
        parsed.scheme != "https"
        or parsed.username
        or parsed.password
        or parsed.query
        or parsed.fragment
        or "%" in parsed.path
        or "\\" in parsed.path
    ):
        return False
    path_parts = parsed.path.split("/")
    if (
        len(path_parts) < 3
        or path_parts[0] != ""
        or any(part in {"", ".", ".."} for part in path_parts[1:])
    ):
        return False
    if package_name == "glaze":
        return (
            len(path_parts) >= 4
            and
            parsed.hostname == "github.com"
            and path_parts[1:3] == ["stephenberry", "glaze"]
        )
    if package_name == "lua5.5":
        return (
            parsed.hostname == "www.lua.org"
            and path_parts[1] in {"ftp", "tests"}
        )
    if package_name in HYPRWM_REPOSITORIES:
        repository = "Hyprland" if package_name == "hyprland" else package_name
        return (
            len(path_parts) >= 4
            and
            parsed.hostname == "github.com"
            and path_parts[1:3] == ["hyprwm", repository]
        )
    return False


def validate_meta_requirements(
    data: dict[str, Any], spec_text: str
) -> list[str]:
    packages = packages_from(data)
    source_overrides = {
        "hyprland-backgrounds": "hyprland",
    }
    errors: list[str] = []
    pattern = re.compile(
        r"^Requires:\s+(\S+)\s*=\s*(\S+)-(\d+)%\{\?dist\}\s*$",
        re.MULTILINE,
    )
    for binary_name, version, release_text in pattern.findall(spec_text):
        source_name = source_overrides.get(binary_name, binary_name)
        if source_name in {"hyprland-desktop", "hyprwm-complete"}:
            continue
        package = packages.get(source_name)
        if not package:
            continue
        if (
            version != package["version"]
            or int(release_text) != package["release"]
        ):
            errors.append(
                f"hyprwm-meta: {binary_name} requirement does not match "
                f"{source_name} {package['version']}-{package['release']}"
            )
    return errors


def validate_plugin_coupling(
    data: dict[str, Any], spec_text: str
) -> list[str]:
    hyprland = packages_from(data)["hyprland"]
    match = re.search(
        r"^%global hyprland_evr\s+(\S+)-(\d+)%\{\?dist\}\s*$",
        spec_text,
        re.MULTILINE,
    )
    if not match:
        return ["hyprland-plugins: missing exact hyprland_evr macro"]
    if (
        match.group(1) != hyprland["version"]
        or int(match.group(2)) != hyprland["release"]
    ):
        return [
            "hyprland-plugins: hyprland_evr does not match "
            f"hyprland {hyprland['version']}-{hyprland['release']}"
        ]
    return []


def validate_manifest(data: dict[str, Any]) -> list[str]:
    errors: list[str] = validate_json_schema(data)
    if data.get("schema_version") != 1:
        errors.append("schema_version must be 1")
    if data.get("fedora_release") != 44:
        errors.append("fedora_release must be 44 for the initial release set")
    if not re.fullmatch(r"[0-9]{4}\.[0-9]{2}\.[0-9]{2}-[0-9]+", str(data.get("revision", ""))):
        errors.append("revision must match YYYY.MM.DD-N")

    packages = data.get("packages")
    if not isinstance(packages, dict):
        return errors + ["packages must be an object"]

    for name, package in sorted(packages.items()):
        prefix = f"{name}: "
        if not PACKAGE_RE.fullmatch(name):
            errors.append(prefix + "invalid source package name")
            continue
        if not isinstance(package, dict):
            errors.append(prefix + "package entry must be an object")
            continue

        try:
            path = package_path(package)
        except PackagingError as error:
            errors.append(prefix + str(error))
            continue

        spec = spec_path(name, package)
        if not path.is_dir():
            errors.append(prefix + f"missing directory {path.relative_to(ROOT)}")
        if not spec.is_file():
            errors.append(prefix + f"missing spec {spec.relative_to(ROOT)}")

        version = package.get("version")
        release = package.get("release")
        tier = package.get("tier")
        if not isinstance(version, str) or not version:
            errors.append(prefix + "version must be a non-empty string")
        if not isinstance(release, int) or release < 1:
            errors.append(prefix + "release must be a positive integer")
        if not isinstance(tier, int) or tier < 0:
            errors.append(prefix + "tier must be a non-negative integer")

        dependencies = package.get("build_after")
        if not isinstance(dependencies, list) or not all(
            isinstance(item, str) and PACKAGE_RE.fullmatch(item)
            for item in dependencies
        ):
            errors.append(prefix + "build_after must contain valid package names")
        else:
            unknown = sorted(set(dependencies) - packages.keys())
            if unknown:
                errors.append(prefix + f"unknown build_after entries: {', '.join(unknown)}")
            if name in dependencies:
                errors.append(prefix + "package cannot build after itself")

        update_policy = package.get("update_policy", "automatic")
        if update_policy not in {"automatic", "manual", "pinned"}:
            errors.append(prefix + "invalid update_policy")
        if update_policy != "automatic" and not isinstance(
            package.get("update_reason"), str
        ):
            errors.append(
                prefix + "manual or pinned updates require update_reason"
            )

        sources = package.get("sources")
        if not isinstance(sources, list):
            errors.append(prefix + "sources must be an array")
        else:
            seen: set[str] = set()
            for source in sources:
                if not isinstance(source, dict):
                    errors.append(prefix + "source entry must be an object")
                    continue
                filename = source.get("filename")
                url = source.get("url")
                digest = source.get("sha256")
                provenance = source.get("provenance")
                reference = source.get("reference")
                if not isinstance(filename, str) or not SOURCE_RE.fullmatch(filename):
                    errors.append(prefix + f"invalid source filename: {filename!r}")
                elif filename in seen:
                    errors.append(prefix + f"duplicate source filename: {filename}")
                else:
                    seen.add(filename)
                if not isinstance(url, str) or not url.startswith("https://"):
                    errors.append(prefix + f"source URL must use HTTPS: {url!r}")
                elif urlparse(url).hostname in FORBIDDEN_SOURCE_HOSTS:
                    errors.append(prefix + f"forbidden source host: {urlparse(url).hostname}")
                if not isinstance(digest, str) or not SHA256_RE.fullmatch(digest):
                    errors.append(prefix + f"invalid SHA-256 for {filename!r}")
                if provenance not in {"official-upstream", "official-fedora"}:
                    errors.append(prefix + f"invalid provenance for {filename!r}")
                elif (
                    provenance == "official-upstream"
                    and isinstance(url, str)
                    and not official_upstream_allowed(name, url)
                ):
                    errors.append(
                        prefix
                        + f"source is not from an approved upstream: {url!r}"
                    )
                elif (
                    provenance == "official-fedora"
                    and isinstance(url, str)
                    and urlparse(url).hostname not in FEDORA_SOURCE_HOSTS
                ):
                    errors.append(
                        prefix
                        + f"official-fedora source uses non-Fedora host: {url!r}"
                    )
                if not isinstance(reference, str) or not reference:
                    errors.append(prefix + f"missing provenance reference for {filename!r}")

        if spec.is_file() and isinstance(version, str) and isinstance(release, int):
            text = spec.read_text(encoding="utf-8")
            version_match = re.search(r"^Version:\s*(\S+)\s*$", text, re.MULTILINE)
            release_match = re.search(r"^Release:\s*(\d+)%\{\?dist\}\s*$", text, re.MULTILINE)
            if not version_match or version_match.group(1) != version:
                errors.append(prefix + "spec Version does not match manifest")
            if not release_match or int(release_match.group(1)) != release:
                errors.append(prefix + "spec Release does not match manifest")
            if "/usr/local" in text:
                errors.append(prefix + "spec must not install below /usr/local")
            if "copr.fedorainfracloud.org" in text:
                errors.append(prefix + "spec must not use COPR repositories")
            if re.search(
                r"^\s*(curl|wget|git\s+clone)\b",
                text,
                re.MULTILINE,
            ):
                errors.append(prefix + "spec contains a build-time network command")
            errors.extend(validate_local_inputs(name, package, text))
            if name == "hyprwm-meta":
                errors.extend(validate_meta_requirements(data, text))
            if name == "hyprland-plugins":
                errors.extend(validate_plugin_coupling(data, text))

    errors.extend(validate_graph(packages))
    return errors


def validate_graph(packages: dict[str, dict[str, Any]]) -> list[str]:
    errors: list[str] = []
    visiting: set[str] = set()
    visited: set[str] = set()

    def visit(name: str, trail: list[str]) -> None:
        if name in visited:
            return
        if name in visiting:
            cycle = trail[trail.index(name) :] + [name]
            errors.append("dependency cycle: " + " -> ".join(cycle))
            return
        visiting.add(name)
        for dependency in packages[name].get("build_after", []):
            if dependency in packages:
                visit(dependency, trail + [dependency])
        visiting.remove(name)
        visited.add(name)

    for name in packages:
        visit(name, [name])
    return errors


def validate_command(args: argparse.Namespace) -> None:
    data = load_manifest()
    errors = validate_manifest(data)
    if errors:
        for error in errors:
            print(f"error: {error}", file=sys.stderr)
        raise PackagingError(f"validation failed with {len(errors)} error(s)")
    print(f"validated {len(packages_from(data))} package manifest entries")


def fetch_source(name: str, source: dict[str, str]) -> Path:
    package_cache = CACHE_ROOT / name
    package_cache.mkdir(parents=True, exist_ok=True)
    destination = package_cache / source["filename"]

    if destination.is_file() and sha256(destination) == source["sha256"]:
        print(f"verified {destination.relative_to(ROOT)}")
        return destination

    destination.unlink(missing_ok=True)
    temporary = destination.with_suffix(destination.suffix + ".part")
    temporary.unlink(missing_ok=True)
    run(
        [
            "curl",
            "--fail",
            "--location",
            "--proto",
            "=https",
            "--tlsv1.2",
            "--retry",
            "3",
            "--output",
            str(temporary),
            source["url"],
        ]
    )
    actual = sha256(temporary)
    if actual != source["sha256"]:
        temporary.unlink(missing_ok=True)
        raise PackagingError(
            f"{name}/{source['filename']}: SHA-256 mismatch: "
            f"expected {source['sha256']}, got {actual}"
        )
    temporary.replace(destination)
    print(f"fetched {destination.relative_to(ROOT)}")
    return destination


def fetch_packages(data: dict[str, Any], names: list[str] | None) -> None:
    for name, package in selected_packages(data, names):
        for source in package["sources"]:
            fetch_source(name, source)


def fetch_command(args: argparse.Namespace) -> None:
    data = load_manifest()
    errors = validate_manifest(data)
    if errors:
        raise PackagingError("manifest must validate before fetching sources")
    fetch_packages(data, args.packages or None)


def prepare_sources(name: str, package: dict[str, Any]) -> Path:
    source_dir = WORK_ROOT / "sources" / name
    if source_dir.exists():
        shutil.rmtree(source_dir)
    source_dir.mkdir(parents=True)

    for source in package["sources"]:
        cached = fetch_source(name, source)
        os.link(cached, source_dir / source["filename"])

    directory = package_path(package)
    for child_name in ("files", "patches"):
        child = directory / child_name
        if not child.is_dir():
            continue
        for item in sorted(child.iterdir()):
            if item.is_file():
                destination = source_dir / item.name
                if destination.exists():
                    raise PackagingError(f"duplicate source filename: {item.name}")
                shutil.copy2(item, destination)
    return source_dir


def result_directory(mock_config: str, name: str, kind: str) -> Path:
    config_name = Path(mock_config).stem
    return RESULTS_ROOT / config_name / name / kind


def build_srpm(
    name: str, package: dict[str, Any], mock_config: str
) -> Path:
    source_dir = prepare_sources(name, package)
    result_dir = result_directory(mock_config, name, "srpm")
    if result_dir.exists():
        shutil.rmtree(result_dir)
    result_dir.mkdir(parents=True)
    run(
        [
            "mock",
            "-r",
            mock_config,
            "--buildsrpm",
            "--spec",
            str(spec_path(name, package)),
            "--sources",
            str(source_dir),
            "--resultdir",
            str(result_dir),
        ],
        cwd=ROOT,
    )
    candidates = sorted(result_dir.glob("*.src.rpm"))
    if len(candidates) != 1:
        raise PackagingError(
            f"expected one source RPM for {name}, found {len(candidates)}"
        )
    return candidates[0]


def srpm_command(args: argparse.Namespace) -> None:
    data = load_manifest()
    errors = validate_manifest(data)
    if errors:
        raise PackagingError("manifest must validate before building")
    packages = dict(selected_packages(data, [args.package]))
    srpm = build_srpm(args.package, packages[args.package], args.mock_config)
    print(srpm)


def build_package(
    name: str,
    package: dict[str, Any],
    mock_config: str,
    repositories: list[Path],
) -> Path:
    srpm = build_srpm(name, package, mock_config)
    result_dir = result_directory(mock_config, name, "rpm")
    if result_dir.exists():
        shutil.rmtree(result_dir)
    result_dir.mkdir(parents=True)
    command = [
        "mock",
        "-r",
        mock_config,
        "--rebuild",
        str(srpm),
        "--resultdir",
        str(result_dir),
    ]
    for repository in repositories:
        if (repository / "repodata" / "repomd.xml").is_file():
            command.extend(["--addrepo", repository.resolve().as_uri()])
    run(command, cwd=ROOT)
    if not list(result_dir.glob("*.rpm")):
        raise PackagingError(f"Mock produced no RPMs for {name}")
    return result_dir


def build_command(args: argparse.Namespace) -> None:
    data = load_manifest()
    errors = validate_manifest(data)
    if errors:
        raise PackagingError("manifest must validate before building")
    packages = dict(selected_packages(data, [args.package]))
    result = build_package(
        args.package,
        packages[args.package],
        args.mock_config,
        [Path(args.repo)],
    )
    print(result)


def affected_package_names(
    data: dict[str, Any], changed: set[str]
) -> set[str]:
    packages = dict(selected_packages(data))
    unknown = sorted(changed - packages.keys())
    if unknown:
        raise PackagingError(f"unknown package(s): {', '.join(unknown)}")

    affected = set(changed)
    progress = True
    while progress:
        progress = False
        for name, package in packages.items():
            if name in affected:
                continue
            if set(package.get("build_after", [])) & affected:
                affected.add(name)
                progress = True

    required = set(affected)
    progress = True
    while progress:
        progress = False
        for name in tuple(required):
            for dependency in packages[name].get("build_after", []):
                if dependency not in required:
                    required.add(dependency)
                    progress = True
    return required


def ordered_packages(
    data: dict[str, Any], names: set[str] | None = None
) -> list[tuple[str, dict[str, Any]]]:
    packages = dict(selected_packages(data))
    if names is not None:
        packages = {name: package for name, package in packages.items() if name in names}
    completed: set[str] = set()
    ordered: list[tuple[str, dict[str, Any]]] = []
    while len(completed) < len(packages):
        ready = [
            (name, package)
            for name, package in packages.items()
            if name not in completed
            and (
                set(package.get("build_after", [])) & packages.keys()
            )
            <= completed
        ]
        if not ready:
            remaining = sorted(set(packages) - completed)
            raise PackagingError(
                "cannot order package graph; remaining: " + ", ".join(remaining)
            )
        ready.sort(key=lambda item: (item[1]["tier"], item[0]))
        for item in ready:
            ordered.append(item)
            completed.add(item[0])
    return ordered


def rpm_files(result_dir: Path) -> list[Path]:
    return [
        path
        for path in result_dir.glob("*.rpm")
        if not path.name.endswith(".src.rpm")
    ]


def revision_epoch(revision: str) -> int:
    date_part, sequence_text = revision.split("-", 1)
    date_part = date_part.replace(".", "-")
    try:
        timestamp = dt.datetime.fromisoformat(
            date_part + "T00:00:00+00:00"
        )
    except ValueError as error:
        raise PackagingError(f"invalid release revision date: {revision}") from error
    return int(timestamp.timestamp()) + int(sequence_text) - 1


def revision_key(revision: str) -> tuple[dt.date, int]:
    date_part, sequence_text = revision.split("-", 1)
    return (
        dt.date.fromisoformat(date_part.replace(".", "-")),
        int(sequence_text),
    )


def refresh_repository(repository: Path, revision: str) -> None:
    packages_dir = repository / "Packages"
    packages_dir.mkdir(parents=True, exist_ok=True)
    command = [
        "createrepo_c",
        "--checksum",
        "sha256",
        "--repomd-checksum",
        "sha256",
        "--unique-md-filenames",
        "--excludes",
        "*.src.rpm",
        "--revision",
        str(revision_epoch(revision)),
        "--set-timestamp-to-revision",
    ]
    comps = ROOT / "repo" / "comps" / "hyprwm.xml"
    if comps.is_file():
        command.extend(["--groupfile", str(comps)])
    if (repository / "repodata" / "repomd.xml").is_file():
        command.append("--update")
    command.append(str(repository))
    run(command)


def add_results_to_repository(result_dir: Path, repository: Path) -> None:
    packages_dir = repository / "Packages"
    packages_dir.mkdir(parents=True, exist_ok=True)
    for rpm in rpm_files(result_dir):
        shutil.copy2(rpm, packages_dir / rpm.name)


def rpm_metadata(path: Path) -> dict[str, str]:
    query_format = (
        "%{NAME}\\t%{VERSION}\\t%{RELEASE}\\t%{ARCH}\\t%{SOURCERPM}\\n"
    )
    fields = output(["rpm", "-qp", "--qf", query_format, str(path)]).strip().split(
        "\t"
    )
    if len(fields) != 5:
        raise PackagingError(f"cannot read RPM metadata from {path}")
    return dict(zip(("name", "version", "release", "arch", "source_rpm"), fields))


def current_artifacts(
    data: dict[str, Any],
    input_root: Path,
    config_name: str,
    *,
    require_complete: bool,
) -> dict[str, dict[str, list[Path]]]:
    artifacts: dict[str, dict[str, list[Path]]] = {}
    missing: list[str] = []
    for source_name, package in selected_packages(data):
        version = package["version"]
        release_prefix = f"{package['release']}."
        package_root = input_root / config_name / source_name
        binary_rpms: list[Path] = []
        for path in sorted((package_root / "rpm").glob("*.rpm")):
            if path.name.endswith(".src.rpm"):
                continue
            metadata = rpm_metadata(path)
            if (
                metadata["version"] == version
                and metadata["release"].startswith(release_prefix)
                and metadata["source_rpm"].startswith(
                    f"{source_name}-{version}-{package['release']}."
                )
            ):
                binary_rpms.append(path)

        source_rpms: list[Path] = []
        for path in sorted((package_root / "srpm").glob("*.src.rpm")):
            metadata = rpm_metadata(path)
            if (
                metadata["name"] == source_name
                and metadata["version"] == version
                and metadata["release"].startswith(release_prefix)
            ):
                source_rpms.append(path)

        if not binary_rpms or len(source_rpms) != 1:
            if require_complete:
                missing.append(source_name)
            continue
        artifacts[source_name] = {
            "rpms": binary_rpms,
            "srpms": source_rpms,
        }

    if missing:
        raise PackagingError(
            f"{config_name}: missing current build artifacts for "
            + ", ".join(missing)
        )
    return artifacts


def copy_unique(source: Path, destination: Path) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    if destination.exists():
        if sha256(source) != sha256(destination):
            raise PackagingError(
                f"artifact filename collision with different content: "
                f"{destination.name}"
            )
        return
    shutil.copy2(source, destination)


def populate_repository(
    data: dict[str, Any],
    input_root: Path,
    config_name: str,
    repository: Path,
    *,
    require_complete: bool,
) -> dict[str, dict[str, list[Path]]]:
    artifacts = current_artifacts(
        data,
        input_root,
        config_name,
        require_complete=require_complete,
    )
    for package_artifacts in artifacts.values():
        for rpm in package_artifacts["rpms"]:
            copy_unique(rpm, repository / "Packages" / rpm.name)
    return artifacts


def build_set_command(args: argparse.Namespace) -> None:
    data = load_manifest()
    errors = validate_manifest(data)
    if errors:
        raise PackagingError("manifest must validate before building")

    repository = Path(args.repo)
    config_name = Path(args.mock_config).stem
    available_names: set[str] = set()
    if args.resume:
        if repository.exists():
            shutil.rmtree(repository)
        (repository / "Packages").mkdir(parents=True)
        available_names = set(
            populate_repository(
                data,
                RESULTS_ROOT,
                config_name,
                repository,
                require_complete=False,
            )
        )
        refresh_repository(repository, data["revision"])
    else:
        if repository.exists():
            shutil.rmtree(repository)
        (repository / "Packages").mkdir(parents=True)
    revision = data["revision"]
    names = (
        affected_package_names(data, set(args.packages))
        if args.packages
        else None
    )
    for name, package in ordered_packages(data, names):
        if args.resume and name in available_names:
            print(f"==> reusing {name}")
            continue
        print(f"==> building {name}")
        result = build_package(name, package, args.mock_config, [repository])
        add_results_to_repository(result, repository)
        refresh_repository(repository, revision)
        available_names.add(name)


